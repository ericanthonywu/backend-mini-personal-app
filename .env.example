# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_NAME=expense_tracker
DB_DEBUG=false

# Email (Gmail IMAP)
# Enable IMAP in Gmail settings + create an App Password
# Google Account -> Security -> 2-Step Verification -> App Passwords
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_TLS=true

# Polling interval in milliseconds (default: 1 hour)
EMAIL_POLL_INTERVAL_MS=3600000

# Budget in IDR (integers only)
WEEKLY_BUDGET=1000000
MONTHLY_BUDGET=5000000

# Auth
# PIN used to login from the mobile app
AUTH_PIN=1234
# Secret for signing JWT tokens — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=30d

# Server
PORT=3000
NODE_ENV=development
